# === Screenpipe (local capture) ===
SCREENPIPE_API_URL=http://localhost:3030
# Get the token with: screenpipe auth token
SCREENPIPE_API_KEY=

# === Curation LLM (OpenRouter) ===
OPENROUTER_API_KEY=
CURATION_MODEL=anthropic/claude-sonnet-4.6

# === Identity / locale ===
# Your name, used in the curation prompt (e.g. "Alex"). Defaults to "the user".
USER_NAME=
USER_TIMEZONE=Europe/Brussels

# === Upload target ===
# "direct" -> Assistant Memory ; "petals" -> Petals proxy
UPLOAD_MODE=direct

# -- direct mode (Assistant Memory) --
MEMORY_API_URL=http://localhost:3000
MEMORY_USER_ID=
# MEMORY_API_KEY=            # optional bearer token

# -- petals mode --
PETALS_BASE_URL=https://petals.chat
# PETALS_API_KEY=            # required when UPLOAD_MODE=petals

# === WhatsApp connector (structured message ingestion) ===
# "auto" -> fold archived WhatsApp messages into the digest when the sidecar
#           archive exists; "off" -> ignore the connector (screen capture only).
WHATSAPP_CONNECTOR=auto
# WHATSAPP_ARCHIVE_PATH=~/.screenpipe-distiller/whatsapp/messages.sqlite
# Group-message relevance: "contacts" (default) keeps only saved address-book
# contacts + your own messages, dropping unknown senders in large/noisy groups;
# "all" keeps every group message. 1:1 chats are never filtered.
WHATSAPP_GROUP_FILTER=contacts
